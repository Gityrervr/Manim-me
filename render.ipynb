import subprocess, glob, os
from IPython.display import Video, display

def render(file, classname, quality='-qh'):
    print(f'Rendering {classname}...')
    result = subprocess.run(
        ['python', '-m', 'manim', quality,
         '--disable_caching', file, classname],
        capture_output=True, text=True
    )
    if result.returncode != 0:
        print('ERROR:', result.stderr[-3000:])
        return
    videos = sorted(glob.glob('media/videos/**/*.mp4', recursive=True))
    if videos:
        latest = videos[-1]
        print(f'Done! {latest}')
        display(Video(latest, width=800))
    else:
        print('No video found')

# Render Thales
render('scenes/thales.py', 'ThalesTheorem')
